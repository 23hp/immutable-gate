{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "/bin/zsh",
      "args": ["-l", "-i", "-c"]
    }
  },
  "presentation": {
    "echo": true,
    "reveal": "always",
    "focus": true,
    "panel": "dedicated",
    "clear": true
  },
  "tasks": [
    {
      "label": "🔧 Prepare PXE Installtion",
      "type": "shell",
      "command": "ansible-playbook pxe-setup.yml"
    },
    {
      "label": "🧹 Cleanup PXE resources",
      "type": "shell",
      "command": "ansible-playbook cleanup.yml"
    },
    {
      "label": "🔧 OS Activation",
      "type": "shell",
      "command": "bws run -- ansible-playbook os-activate.yml"
    },
    {
      "label": "🔧 OS Patch",
      "type": "shell",
      "command": "bws run -- ansible-playbook os-patch.yml"
    },
    {
      "label": "🚀 OS Reset",
      "type": "shell",
      "command": "bws run -- ansible-playbook os-reset.yml"
    },
    {
      "label": "🚀 OS Destroy",
      "type": "shell",
      "command": "ansible-playbook os-destroy.yml"
    },
  ]
}
