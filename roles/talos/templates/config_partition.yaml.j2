---
apiVersion: v1alpha1
kind: VolumeConfig
name: STATE
encryption:
  provider: luks2
  keys:
    - slot: 0
      tpm: {}
---
apiVersion: v1alpha1
kind: VolumeConfig
name: EPHEMERAL
provisioning:
  maxSize: 200GiB
encryption:
  provider: luks2
  keys:
    - slot: 0
      tpm: {}
      lockToState: true
  options:
    - no_read_workqueue
    - no_write_workqueue
---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: local-data
volumeType: partition
provisioning:
  diskSelector:
    match: disk.dev_path == '{{ talos_install_disk }}'
  minSize: 1000GiB
encryption:
  provider: luks2
  keys:
    - slot: 0
      tpm: {}
    - slot: 1
      static:
        passphrase: {{ talos_disk_passphrase }}
  options:
    - no_read_workqueue
    - no_write_workqueue
