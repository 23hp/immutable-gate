#!ipxe

set talos-version {{talos_version}}
set arch {{talos_device_arch}}
set config-url {{talos_config_url}}

set base-url https://github.com/siderolabs/talos/releases/download/${talos-version}

imgfree
kernel ${base-url}/vmlinuz-${arch} talos.config=${config-url} talos.platform=metal console=tty0 init_on_alloc=1 slab_nomerge pti=on consoleblank=0 nvme_core.io_timeout=4294967295 printk.devkmsg=on selinux=1 module.sig_enforce=1
initrd ${base-url}/initramfs-${arch}.xz
boot


